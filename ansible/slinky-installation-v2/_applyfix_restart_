kubectl delete nodeset -n slurm slurm-worker-slinky

cat <<EOF > slurm-values.yaml
configFiles:
  gres.conf: |
    AutoDetect=nvidia

slurm:
  conf:
    GresTypes: gpu
  nodes:
    - name: "slinky-0"
      cpus: 20
      realMemory: 210000
      gres: "gpu:1"

# THE FIX: Resources must be nested under the specific NodeSet name
nodesets:
  slinky:
    slurmd:
      resources:
        limits:
          nvidia.com/gpu: 1
          cpu: "20"
          memory: "210Gi"
        requests:
          nvidia.com/gpu: 1
          cpu: "20"
          memory: "210Gi"
      env:
        - name: NVIDIA_VISIBLE_DEVICES
          value: "all"
        - name: NVIDIA_DRIVER_CAPABILITIES
          value: "compute,utility"
        - name: LD_LIBRARY_PATH
          value: "/usr/local/nvidia/lib64"
EOF

helm upgrade slurm oci://ghcr.io/slinkyproject/charts/slurm \
  --version 1.0.2 \
  --namespace slurm \
  -f slurm-values.yaml

kubectl delete pod -n slurm slurm-controller-0 slurm-worker-slinky-0
k get pods -A -w
